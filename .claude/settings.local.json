{
  "permissions": {
    "allow": [
      "Bash(jj status:*)",
      "Bash(jj log:*)",
      "Bash(./rebuild.sh)",
      "Bash(jj snapshot:*)",
      "Bash(nix eval:*)",
      "Bash(git add:*)",
      "WebSearch",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:bbs.archlinux.org)",
      "Bash(systemctl status:*)"
    ]
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": false,
    "allowUnsandboxedCommands": true
  }
}
